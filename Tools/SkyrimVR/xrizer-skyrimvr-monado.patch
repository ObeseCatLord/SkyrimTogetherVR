+        let mut events = VecDeque::from([OverlayEvent::keyboard_done(0x1234, 0x5678)]);
+        let required_size = std::mem::offset_of!(vr::VREvent_t, data)
+            + std::mem::size_of::<vr::VREvent_Keyboard_t>();
