+fn keyboard_done_event_survives_an_undersized_poll() {
+    let f = Fixture::new();
+    f.input.events.lock().unwrap().clear();
+    f.input.enqueue_keyboard_done(0x1234, 0x5678);
+
+    let required_size =
+        std::mem::offset_of!(vr::VREvent_t, data) + std::mem::size_of::<vr::VREvent_Keyboard_t>();
+    let mut event = vr::VREvent_t::default();
+    assert!(
+        !f.input
+            .get_next_event((required_size - 1) as u32, &mut event)
+    );
+    assert!(matches!(
+        f.input
+            .events
+            .lock()
+            .unwrap()
+            .front()
+            .map(|event| &event.data),
+        Some(super::InputEventData::Keyboard(_))
+    ));
+
+    assert!(
+        f.input
+            .get_next_event(std::mem::size_of::<vr::VREvent_t>() as u32, &mut event)
+    );
+    let event_type = unsafe { (&raw const event.eventType).read_unaligned() };
+    let device_index = unsafe { (&raw const event.trackedDeviceIndex).read_unaligned() };
+    let keyboard = unsafe { (&raw const event.data.keyboard).read_unaligned() };
+    assert_eq!(event_type, vr::EVREventType::KeyboardDone as u32);
+    assert_eq!(device_index, vr::k_unTrackedDeviceIndexInvalid);
+    assert_eq!(keyboard.cNewInput, [0; 8]);
+    assert_eq!(keyboard.uUserValue, 0x1234);
+    assert_eq!(keyboard.overlayHandle, 0x5678);
+    f.input.events.lock().unwrap().clear();
