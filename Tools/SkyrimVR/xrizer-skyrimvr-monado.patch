+
+        assert!(!poll_overlay_event(
+            &mut events,
+            &mut event,
+            (required_size - 1) as u32,
+        ));
+        assert_eq!(events.len(), 1);
+        assert!(poll_overlay_event(
+            &mut events,
+            &mut event,
+            std::mem::size_of::<vr::VREvent_t>() as u32,
+        ));
+
+        let event_type = unsafe { (&raw const event.eventType).read_unaligned() };
+        let device_index = unsafe { (&raw const event.trackedDeviceIndex).read_unaligned() };
+        let keyboard = unsafe { (&raw const event.data.keyboard).read_unaligned() };
+        assert_eq!(event_type, vr::EVREventType::KeyboardDone as u32);
+        assert_eq!(device_index, vr::k_unTrackedDeviceIndexInvalid);
+        assert_eq!(keyboard.cNewInput, [0; 8]);
