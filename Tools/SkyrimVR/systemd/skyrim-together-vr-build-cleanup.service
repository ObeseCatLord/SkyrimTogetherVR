[Unit]
Description=Clean stale Skyrim Together VR build storage

[Service]
Type=oneshot
ExecStart=%h/Documents/SkyrimModding/SkyrimTogetherVR/Tools/SkyrimVR/cleanup_build_storage.sh --scheduled --max-age-days 2 --rebuildable-caches --temp-artifacts
Restart=on-failure
RestartSec=5m
TimeoutStartSec=30m
